# Required: Supabase project API URL and service-role key.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<supabase-service-role-key>

# Required for schema migrations and scheduled retention cleanup.
DATABASE_URL=postgresql://<postgres-user>:<postgres-password>@<postgres-host>:5432/postgres

# Required for production app/key administration. Use this as the bearer
# token for /v1/apps, /v1/apps/<application_id>/api-keys, and key revocation.
CADENCE_ADMIN_TOKEN=<random-32-byte-or-longer-secret>
# Local/demo-only escape hatch. Leave unset or 0 in production so admin
# endpoints fail closed if CADENCE_ADMIN_TOKEN is missing.
CADENCE_ALLOW_OPEN_ADMIN=0

# Required for stable keystroke encryption across restarts. Generate once and
# store the complete PEM, preserving newlines in your secret manager.
# python - <<'PY'
# from cryptography.hazmat.primitives.asymmetric import rsa
# from cryptography.hazmat.primitives import serialization
# key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
# print(key.private_bytes(
#     serialization.Encoding.PEM,
#     serialization.PrivateFormat.PKCS8,
#     serialization.NoEncryption(),
# ).decode())
# PY
CADENCE_RSA_PRIVATE_KEY=<pem-private-key>

# Required for email 2FA outside demo mode.
RESEND_KEY=<resend-api-key>
RESEND_FROM_EMAIL=team@cadence-capstone.us
CADENCE_DEMO_MODE=0

# Comma-separated frontend origins allowed by browser CORS.
CADENCE_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Required for multi-instance production rate limiting. Requires the Redis
# Python client from backend/requirements.txt. Example:
# redis://default:<password>@<host>:6379/0
CADENCE_RATE_LIMIT_STORAGE_URI=redis://<redis-url>
CADENCE_ADMIN_RATE_LIMIT=30 per minute; 300 per hour
CADENCE_PUBLIC_REGISTRATION_RATE_LIMIT=10 per minute; 100 per hour
CADENCE_PLATFORM_WRITE_RATE_LIMIT=120 per minute; 5000 per hour
CADENCE_PLATFORM_SCORE_RATE_LIMIT=240 per minute; 10000 per hour
CADENCE_RAW_DATA_RETENTION_DAYS=90
CADENCE_REGISTRATION_RETENTION_DAYS=365

# Optional model/runtime tuning.
CADENCE_REQUIRED_ENROLLMENT_SAMPLES=5
CADENCE_ENROLLMENT_LIMIT=10
CADENCE_PASSWORD_ATTEMPT_THRESHOLD=5
CADENCE_MODEL_PATH=/app/models/cadence_base_model.keras
CADENCE_MODEL_METRICS_PATH=/app/models/cadence_base_model.metrics.json
