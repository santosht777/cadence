# ---------------------------------------------------------------------------
# Cadence Developer Console — environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and adjust as needed:
#
#     cp .env.example .env.local
#
# Only NEXT_PUBLIC_* variables are exposed to the browser. This console talks
# to the Cadence backend directly from the browser using the *developer*
# access token (Supabase auth) — never a server-side sk_live_ API key.
# ---------------------------------------------------------------------------

# Base URL of the Cadence backend API.
# Local development default is http://localhost:5001.
# In production, point this at your deployed Cadence API origin, e.g.
#   NEXT_PUBLIC_CADENCE_API_BASE_URL=https://api.cadence.example.com
NEXT_PUBLIC_CADENCE_API_BASE_URL=http://localhost:5001
